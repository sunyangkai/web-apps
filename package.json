{
  "name": "micro-frontend-root",
  "version": "1.0.0",
  "description": "Micro Frontend Architecture with React 16 and Module Federation",
  "private": true,
  "packageManager": "pnpm@8.15.0",
  "engines": {
    "node": ">=16.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "build:test": "NODE_ENV=test turbo run build",
    "build:prod": "NODE_ENV=production turbo run build",
    "clean": "turbo run clean",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "dev:base": "turbo run dev --filter=base",
    "dev:user": "turbo run dev --filter=user",
    "dev:sale": "turbo run dev --filter=sale",
    "dev:host": "turbo run dev --filter=host",
    "dev:local-user": "cd packages/host && pnpm dev:local-user",
    "dev:local-sale": "cd packages/host && pnpm dev:local-sale",
    "dev:local-base": "cd packages/host && pnpm dev:local-base",
    "dev:test": "cd packages/host && pnpm dev:test",
    "dev:staging": "cd packages/host && pnpm dev:staging",
    "build:base": "turbo run build --filter=base",
    "build:user": "turbo run build --filter=user",
    "build:sale": "turbo run build --filter=sale",
    "build:host": "turbo run build --filter=host",
    "clean:all": "pnpm -r run clean && rimraf node_modules packages/*/node_modules",
    "reset": "pnpm run clean:all && pnpm install",
    "graph": "turbo run build --graph",
    "cache:clear": "turbo run build --force",
    "sm:init": "git submodule update --init --recursive",
    "sm:update": "git submodule update --remote --merge",
    "sm:push": "git submodule foreach 'git push' && git push",
    "sm:pull": "git submodule foreach 'git pull' && git pull",
    "sm:status": "git submodule foreach 'git status'"
  },
  "devDependencies": {
    "dotenv-webpack": "^8.1.1",
    "prettier": "^3.0.0",
    "rimraf": "^5.0.0",
    "turbo": "^1.11.0"
  }
}
